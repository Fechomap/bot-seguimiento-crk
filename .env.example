# Configuración de Telegram
TELEGRAM_TOKEN_SOPORTE=123456789:your_telegram_bot_token_here

# Configuración de API
API_BASE_URL=https://api.example.com

# Configuración para OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo-0125  # Modelo recomendado para empezar
OPENAI_MAX_TOKENS=500            # Límite de tokens para la respuesta
OPENAI_TEMPERATURE=0.7           # Creatividad de las respuestas (0.0-1.0)

# Configuración de modos de interfaz
DEFAULT_MODE=conversational       # conversational, traditional
SHOW_SUGGESTIONS=true             # Mostrar sugerencias de preguntas

# Configuración para caché y optimización
CACHE_EXPIRY=3600                # Tiempo de expiración de caché en segundos (1 hora)
RESPONSE_CACHE_SIZE=100          # Número máximo de respuestas en caché
RETRY_ATTEMPTS=2                 # Número de reintentos para solicitudes a OpenAI
RETRY_DELAY=1000                 # Tiempo entre reintentos en milisegundos
USE_INTENT_DETECTION=true        # Usar detección de intenciones básica (sin OpenAI)
FORCE_AI_THRESHOLD=0.4           # Umbral de confianza para forzar uso de IA

# Configuración general
NODE_ENV=development              # development, production
LOG_LEVEL=info                    # debug, info, warn, error
SESSION_EXPIRY=60                 # Tiempo de expiración de sesión en minutos

# Configuración de seguridad (Opcional - para fase futura)
# Permite definir qué IDs de chat tienen permiso para usar el bot
# ALLOWED_CHAT_IDS=123456789,987654321  # Dejar comentado para permitir a todos los usuarios